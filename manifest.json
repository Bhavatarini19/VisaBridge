{
  "manifest_version": 3,
  "name": "LinkedIn Keyword Finder",
  "version": "1.0",
  "description": "Highlights visa/sponsorship keywords in LinkedIn job descriptions and shows counts.",
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkedIn Keyword Finder"
  }
}
